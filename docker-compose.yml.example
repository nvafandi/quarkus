services:
  # PostgreSQL Database
  postgres:
    image: postgres:18
    container_name: sales-postgres
    environment:
      POSTGRES_DB: sales_db
      POSTGRES_USER: your_username
      POSTGRES_PASSWORD: your_password
    ports:
      - "5432:5432"
    volumes:
      - postgres_data:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U your_username"]
      interval: 10s
      timeout: 5s
      retries: 5

  # Keycloak SSO Server
  keycloak:
    image: quay.io/keycloak/keycloak:26.0
    container_name: sales-keycloak
    environment:
      KEYCLOAK_ADMIN: admin
      KEYCLOAK_ADMIN_PASSWORD: admin
      KC_DB: postgres
      KC_DB_URL_HOST: postgres
      KC_DB_URL_PORT: 5432
      KC_DB_URL_DATABASE: keycloak_db
      KC_DB_USERNAME: your_username
      KC_DB_PASSWORD: your_password
      KC_HEALTH_ENABLED: "true"
    ports:
      - "8180:8080"
    command: start-dev --import-realm
    volumes:
      - ./keycloak/realm:/opt/keycloak/data/import
      - keycloak_data:/opt/keycloak/data/h2
    depends_on:
      postgres:
        condition: service_healthy
    healthcheck:
      test: ["CMD-SHELL", "curl -f http://localhost:8080/health/ready || exit 1"]
      interval: 10s
      timeout: 5s
      retries: 10

  # Quarkus Sales Application
  app:
    build:
      context: .
      dockerfile: src/main/docker/Dockerfile.jvm
    container_name: sales-app
    environment:
      QUARKUS_DATASOURCE_USERNAME: your_username
      QUARKUS_DATASOURCE_PASSWORD: your_password
      QUARKUS_DATASOURCE_JDBC_URL: jdbc:postgresql://postgres:5432/sales_db
      QUARKUS_OIDC_AUTH_SERVER_URL: http://keycloak:8080/realms/sales-realm
      QUARKUS_OIDC_CLIENT_ID: sales-client
      QUARKUS_OIDC_CREDENTIALS_SECRET: your_client_secret
    ports:
      - "8080:5000"
    depends_on:
      postgres:
        condition: service_healthy
      keycloak:
        condition: service_healthy

volumes:
  postgres_data:
  keycloak_data:
