# @@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@
# Sales System - Environment Configuration Template
# @@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@
#
# IMPORTANT:
#   1. Copy this file to .env (DO NOT TRACK .env in git)
#   2. .env is already in .gitignore - DO NOT REMOVE IT
#   3. Update values with your actual credentials
#   4. NEVER commit real passwords or secrets to git
#
# Usage:
#   docker-compose up -d
#   (Automatically loads .env file with all variables)
#
# =========================================================================
# POSTGRESQL CONFIGURATION
# =========================================================================

# Database name (created automatically)
POSTGRES_DB=sales_db

# PostgreSQL admin username
POSTGRES_USER=your_postgres_username

# PostgreSQL admin password (CHANGE THIS!)
# ⚠️  SECURITY: Use strong password (12+ chars, mixed case, numbers, symbols)
POSTGRES_PASSWORD=your_secure_password_here

# =========================================================================
# KEYCLOAK CONFIGURATION
# =========================================================================

# Keycloak master admin username
KEYCLOAK_ADMIN=admin

# Keycloak master admin password (CHANGE THIS!)
# ⚠️  SECURITY: Use strong password for production
KEYCLOAK_ADMIN_PASSWORD=your_keycloak_admin_password

# Keycloak database (auto-created, usually separate from sales_db)
KEYCLOAK_DB_DATABASE=keycloak_db

# Keycloak database username (should match POSTGRES_USER)
KEYCLOAK_DB_USERNAME=your_postgres_username

# Keycloak database password (should match POSTGRES_PASSWORD)
KEYCLOAK_DB_PASSWORD=your_secure_password_here

# =========================================================================
# QUARKUS APPLICATION CONFIGURATION
# =========================================================================

# Sales app database username (should match POSTGRES_USER)
QUARKUS_DATASOURCE_USERNAME=your_postgres_username

# Sales app database password (should match POSTGRES_PASSWORD)
QUARKUS_DATASOURCE_PASSWORD=your_secure_password_here

# OAuth2 client ID (defined in Keycloak realm)
QUARKUS_OIDC_CLIENT_ID=sales-client

# OAuth2 client secret (generate in Keycloak admin console)
# ⚠️  SECURITY: CRITICAL - Must match secret in Keycloak configuration
# Steps to get:
#   1. Open http://localhost:8180/admin
#   2. Go to: sales-realm → Clients → sales-client → Credentials
#   3. Copy the "Client secret" value
QUARKUS_OIDC_CREDENTIALS_SECRET=your_client_secret_from_keycloak

# =========================================================================
# CONTAINER CONFIGURATION (OPTIONAL)
# =========================================================================

# Container names (for easier management)
POSTGRES_CONTAINER_NAME=postgres
KEYCLOAK_CONTAINER_NAME=keycloak
APP_CONTAINER_NAME=sales-app

# =========================================================================
# PORT MAPPING (OPTIONAL)
# =========================================================================

# PostgreSQL database port on host machine
# Access from host: localhost:POSTGRES_PORT
POSTGRES_PORT=5432

# Keycloak admin console port on host machine
# Access from host: http://localhost:KEYCLOAK_PORT
KEYCLOAK_PORT=8180

# Sales API port on host machine
# Access from host: http://localhost:APP_PORT
# Note: Quarkus app runs on 5000 internally, mapped to APP_PORT on host
APP_PORT=8080

# Quarkus internal port (inside container)
# Usually 5000 for Quarkus (do not change unless you modify Dockerfile)
QUARKUS_INTERNAL_PORT=5000

# =========================================================================
# DOCKER IMAGE VERSIONS (OPTIONAL)
# =========================================================================

# PostgreSQL version to use
# Options: 15, 16, 17, 18 (18 recommended)
POSTGRES_IMAGE_VERSION=18

# Keycloak version to use
# ⚠️  WARNING: Use 24.0 only! Versions 25+ have credential persistence bug
# See README.md for details
KEYCLOAK_IMAGE_VERSION=24.0

# =========================================================================
# SERVICE URLS (FOR REFERENCE - DO NOT MODIFY)
# =========================================================================

# PostgreSQL JDBC connection string (constructed from above variables)
# DATABASE_URL=jdbc:postgresql://postgres:5432/sales_db

# Keycloak base URL (internal Docker network)
# KEYCLOAK_URL=http://keycloak:8080

# Keycloak realm endpoint
# KEYCLOAK_REALM_URL=http://keycloak:8080/realms/sales-realm

# =========================================================================
# SECURITY CHECKLIST FOR PRODUCTION
# =========================================================================
#
# ✅ Before deploying to production:
#   [ ] Change POSTGRES_PASSWORD to a strong random password
#   [ ] Change KEYCLOAK_ADMIN_PASSWORD to a strong random password
#   [ ] Get real QUARKUS_OIDC_CREDENTIALS_SECRET from Keycloak
#   [ ] Use strong passwords (12+ chars, uppercase, lowercase, numbers, symbols)
#   [ ] Do NOT commit .env to git (already in .gitignore)
#   [ ] Store .env securely (never share in messages/emails)
#   [ ] Use secret management tool (HashiCorp Vault, AWS Secrets Manager)
#   [ ] Rotate credentials regularly
#   [ ] Use HTTPS for Keycloak (reverse proxy with TLS)
#   [ ] Set resource limits in docker-compose (memory, CPU)
#
# =========================================================================
# QUICK START
# =========================================================================
#
# 1. Copy this file:
#    cp .env.example .env
#
# 2. Edit .env with your actual values
#
# 3. Start services:
#    docker-compose up -d
#
# 4. Check status:
#    docker-compose ps
#
# 5. View logs:
#    docker-compose logs -f
#
# 6. Get Keycloak client secret:
#    - Open http://localhost:8180/admin
#    - Login with admin / admin (from .env)
#    - Go to: sales-realm → Clients → sales-client → Credentials
#    - Copy Client secret and update QUARKUS_OIDC_CREDENTIALS_SECRET in .env
#    - docker-compose restart app
#
# =========================================================================

